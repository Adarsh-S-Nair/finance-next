# ============================================================
# Zentari — Test Environment Variables
# ============================================================
# Copy this file to .env.test and fill in your test values.
# NEVER commit .env.test to source control.
#
# This environment uses:
#   - PLAID_ENV=mock  → Mock Plaid client (no real API calls)
#   - A separate Supabase project for test data
#     (never share the test Supabase project with production)
#
# To start the app in test mode:
#   cp .env.test.example .env.test
#   npm run dev:test
# ============================================================

# ------------------------------------------------------------------
# Plaid (Mock Mode)
# ------------------------------------------------------------------
# Must be exactly "mock" to activate the mock Plaid client.
# Set to sandbox/development/production to use real Plaid.
PLAID_ENV=mock

# Exposes test mode flag to the client. Set to "true" when PLAID_ENV=mock.
# This causes a "TEST" badge to appear in the sidebar next to the logo.
# Do NOT add this to production env files.
NEXT_PUBLIC_TEST_MODE=true

# These values are not used in mock mode but must be present
# for environment validation (use any non-empty strings).
PLAID_CLIENT_ID=mock_client_id
PLAID_SECRET=mock_secret

# ------------------------------------------------------------------
# Supabase (Test Project)
# ------------------------------------------------------------------
# Create a separate Supabase project for testing at https://supabase.com
# Apply all migrations with: supabase db push --db-url <TEST_DB_URL>
# or via the Supabase dashboard SQL editor.
#
# Replace these with your TEST project's values:
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-anon-key

# Service role key — used by seed scripts to bypass RLS.
# Keep this secret. NEVER expose in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key

# Database connection URL — used by seed scripts.
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------
# Optional: OpenAI (if using AI features in test)
# ------------------------------------------------------------------
# OPENAI_API_KEY=sk-test-...

# ------------------------------------------------------------------
# Optional: Other external services
# ------------------------------------------------------------------
# Set these only if you want to test integrations that need them.
# AXIOM_TOKEN=
# AXIOM_DATASET=
