# ============================================================
# Zervo — Production Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local (or any real credentials) to source control.
#
# This environment uses:
#   - PLAID_ENV=production  → Real Plaid API calls
#   - Your production Supabase project
#
# To start the app:
#   cp .env.example .env.local
#   npm run dev
# ============================================================

# ------------------------------------------------------------------
# Plaid
# ------------------------------------------------------------------
# Set to sandbox, development, or production.
PLAID_ENV=production

PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# Platform-wide AES-256 encryption key. Encrypts plaid_items.access_token /
# accounts.access_token at rest AND platform_config secrets (admin-managed
# Anthropic key etc). Must decode to exactly 32 bytes (64 hex chars preferred).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Legacy alias `PLAID_TOKEN_ENCRYPTION_KEY` is still read as a fallback if
# `PLATFORM_ENCRYPTION_KEY` is unset.
PLATFORM_ENCRYPTION_KEY=your-64-char-hex-key

# ------------------------------------------------------------------
# Supabase (Production Project)
# ------------------------------------------------------------------
# Get these from your Supabase project dashboard at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used by server-side code to bypass RLS.
# Keep this secret. NEVER expose in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database connection URL — used by migrations/seed scripts.
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ------------------------------------------------------------------
# Optional: OpenAI (if using AI features)
# ------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------
# Optional: Other external services
# ------------------------------------------------------------------
# AXIOM_TOKEN=
# AXIOM_DATASET=
